<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Match Quiz | Final Score Celebration 🎉</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: system-ui, -apple-system, 'Segoe UI', 'Inter', 'Helvetica Neue', sans-serif;
            background: #eef2f8;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 1.5rem;
            position: relative;
        }

        /* main quiz container */
        .quiz-box {
            max-width: 1000px;
            width: 100%;
            background: #ffffff;
            border-radius: 2rem;
            box-shadow: 0 20px 35px -12px rgba(0, 0, 0, 0.08), 0 1px 2px rgba(0, 0, 0, 0.02);
            overflow: hidden;
            transition: all 0.2s ease;
            position: relative;
            z-index: 10;
        }

        /* header with final score badge (shown after completion) */
        .quiz-header {
            padding: 1.2rem 2rem 0.8rem 2rem;
            background: white;
            border-bottom: 1px solid #eef2f6;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .title-area h2 {
            font-size: 1.65rem;
            font-weight: 600;
            color: #1a3b4f;
            letter-spacing: -0.2px;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .title-area h2:before {
            content: "🧠";
            font-size: 1.7rem;
        }

        .final-score-badge {
            background: linear-gradient(135deg, #f0f6fa 0%, #e4edf5 100%);
            border-radius: 3rem;
            padding: 0.4rem 1.4rem;
            text-align: center;
            border: 1px solid #cbdde9;
            transition: all 0.3s ease;
        }

        .final-score-label {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 700;
            color: #2c7da0;
        }

        .final-score-value {
            font-size: 1.6rem;
            font-weight: 800;
            color: #1f5e7e;
            line-height: 1.2;
        }

        .final-score-value span {
            font-size: 0.9rem;
            font-weight: 500;
        }

        .perfect-score-top {
            background: linear-gradient(135deg, #ffecb3, #ffe0a3);
            border-color: #e6b422;
        }

        .perfect-score-top .final-score-value {
            color: #b45f06;
        }

        .step-badge {
            display: inline-flex;
            align-items: center;
            background: #e4edf5;
            padding: 0.3rem 1rem;
            border-radius: 40px;
            font-size: 0.75rem;
            font-weight: 500;
            color: #1f5e7e;
            margin-top: 0.25rem;
        }

        /* matching area */
        .match-area {
            position: relative;
            display: flex;
            gap: 2rem;
            padding: 2rem 2rem 1.8rem 2rem;
            background: #fefefe;
            flex-wrap: wrap;
        }

        .col {
            flex: 1;
            min-width: 220px;
        }

        .col-title {
            font-size: 0.7rem;
            text-transform: uppercase;
            font-weight: 700;
            letter-spacing: 1px;
            color: #5e7a93;
            margin-bottom: 1rem;
            padding-left: 0.5rem;
        }

        /* cards style */
        .card {
            background: white;
            border: 1.5px solid #e2edf2;
            border-radius: 1.2rem;
            padding: 1rem 1.2rem;
            margin-bottom: 1rem;
            cursor: pointer;
            transition: all 0.2s ease;
            font-weight: 500;
            font-size: 0.95rem;
            line-height: 1.4;
            color: #1e2f3e;
            box-shadow: 0 1px 2px rgba(0,0,0,0.02);
        }

        .left .card {
            border-left: 5px solid #2c7da0;
        }

        .right .card {
            border-left: 3px solid transparent;
        }

        .card.active {
            background: #f1f9ff;
            border-color: #2c7da0;
            box-shadow: 0 4px 10px rgba(44,125,160,0.1);
        }

        .card.selected {
            background: #fff0cf;
            border-color: #e6b422;
            transform: scale(1.01);
        }

        .card:active {
            transform: scale(0.99);
        }

        .left .card:hover:not(.disabled-touch) {
            background: #f5fafd;
            border-left-color: #1f6e8c;
        }

        .right .card:hover {
            background: #fef8ef;
            border-color: #d9c8a5;
        }

        .hidden {
            display: none;
        }

        /* SVG line layer */
        .line-layer {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
        }

        svg {
            width: 100%;
            height: 100%;
        }

        /* footer */
        .action-footer {
            padding: 1rem 2rem 2rem 2rem;
            background: white;
            border-top: 1px solid #edf2f7;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .next-btn {
            background: #1f5e7e;
            color: white;
            border: none;
            padding: 0.7rem 1.8rem;
            border-radius: 3rem;
            font-weight: 600;
            font-size: 0.9rem;
            cursor: pointer;
            transition: 0.2s;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            box-shadow: 0 2px 5px rgba(0,0,0,0.05);
        }

        .next-btn:hover {
            background: #0f4864;
            transform: translateY(-1px);
        }

        .next-btn:active {
            transform: translateY(1px);
        }

        .message-area {
            font-size: 0.85rem;
            color: #557c8f;
            background: #f0f6fa;
            padding: 0.4rem 1rem;
            border-radius: 3rem;
        }

        /* result panel (detailed feedback) */
        .result-panel {
            margin: 0 2rem 1.8rem 2rem;
            padding: 1rem 1.5rem;
            background: #f8fbfe;
            border-radius: 1.5rem;
            border-left: 5px solid #2c7da0;
            font-size: 0.9rem;
            line-height: 1.5;
            color: #1e3a4d;
            transition: all 0.2s;
        }

        .score-highlight {
            background: #e0f0f5;
            border-radius: 2rem;
            padding: 0.3rem 1rem;
            display: inline-block;
            font-weight: 600;
            margin-top: 0.7rem;
        }

        .celebration-badge {
            background: #ffecb3;
            color: #b45f06;
            margin-left: 0.5rem;
            padding: 0.2rem 0.7rem;
            border-radius: 30px;
            font-size: 0.75rem;
            font-weight: bold;
        }

        .footnote-simple {
            font-size: 0.7rem;
            text-align: center;
            padding: 0 1rem 1.2rem 1rem;
            color: #8195aa;
        }

        @media (max-width: 650px) {
            .match-area {
                flex-direction: column;
                gap: 1rem;
            }
            .quiz-header {
                flex-direction: column;
                align-items: flex-start;
            }
            .title-area h2 {
                font-size: 1.3rem;
            }
            .final-score-value {
                font-size: 1.4rem;
            }
        }

        /* canvas for confetti */
        #confetti-canvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 1000;
        }
    </style>
</head>
<body>

<canvas id="confetti-canvas"></canvas>

<div class="quiz-box">
    <div class="quiz-header">
        <div class="title-area">
            <h2>Match & Learn</h2>
            <div class="step-badge" id="stepIndicator">📘 Step 1 · Question 9</div>
        </div>
        <!-- Final score badge (hidden initially, appears after completion) -->
        <div class="final-score-badge" id="finalScoreBadge" style="display: none;">
            <div class="final-score-label">🏆 FINAL SCORE</div>
            <div class="final-score-value" id="finalScoreValue">0 <span>/ 2</span></div>
        </div>
    </div>

    <div class="match-area" id="matchContainer">
        <!-- LEFT: questions -->
        <div class="col left">
            <div class="col-title">📋 SCENARIO</div>
            <div class="card q-item q0 active" data-id="Q9">
                <strong>9.</strong> Marketing research should be done by external researchers
            </div>
            <div class="card q-item q1 hidden" data-id="Q10">
                <strong>10.</strong> NOT required quality attribute of a marketing researcher
            </div>
        </div>

        <!-- RIGHT: answers -->
        <div class="col right">
            <div class="col-title">✓ SELECT YOUR ANSWER</div>
            <!-- Answers for Q9 -->
            <div class="card ans-block q9-group" data-id="no">❌ No — internal teams are often essential</div>
            <div class="card ans-block q9-group" data-id="yes">✅ Yes — always external for objectivity</div>

            <!-- Answers for Q10 (hidden at first) -->
            <div class="card ans-block q10-group hidden" data-id="B">📊 Postgraduate & statistician (not mandatory)</div>
            <div class="card ans-block q10-group hidden" data-id="A">🎓 Professional and knowledgeable</div>
            <div class="card ans-block q10-group hidden" data-id="C">⚡ Ethical and energetic</div>
            <div class="card ans-block q10-group hidden" data-id="D">🏆 Experience and critical mindset</div>
        </div>

        <div class="line-layer" id="lineLayer">
            <svg id="connectionSvg" width="100%" height="100%"></svg>
        </div>
    </div>

    <div class="action-footer">
        <div class="message-area" id="hintMsg">✨ Click a blue question, then tap an answer</div>
        <button class="next-btn" id="nextBtn">Next step →</button>
    </div>

    <div id="resultArea" style="display: none;"></div>
    <div class="footnote-simple">✔ Match each question with the correct answer. Final score appears at the top when quiz is complete.</div>
</div>

<script>
    (function() {
        // ---------- DOM elements ----------
        const svg = document.getElementById("connectionSvg");
        const container = document.querySelector(".match-area");
        const leftCards = document.querySelectorAll(".left .q-item");
        const rightCards = document.querySelectorAll(".right .ans-block");
        const nextButton = document.getElementById("nextBtn");
        const stepIndicator = document.getElementById("stepIndicator");
        const resultArea = document.getElementById("resultArea");
        const hintMsg = document.getElementById("hintMsg");
        const finalScoreBadge = document.getElementById("finalScoreBadge");
        const finalScoreValueSpan = document.getElementById("finalScoreValue");
        
        // groups
        const q9Answers = document.querySelectorAll(".q9-group");
        const q10Answers = document.querySelectorAll(".q10-group");
        const q0Card = document.querySelector(".q0");
        const q1Card = document.querySelector(".q1");

        // state
        let currentStep = 0;            // 0 = Q9, 1 = Q10, 2 = finished
        let selectedLeftCard = null;
        let matches = [];               // { leftId, rightId }
        let confettiTriggeredForPerfect = false;

        // correct mapping
        const correctMap = {
            Q9: "no",
            Q10: "B"
        };

        // ----- Helper: compute current score based on matches & correctMap
        function computeCurrentScore() {
            let score = 0;
            if (matches.some(m => m.left === "Q9" && m.right === correctMap.Q9)) score++;
            if (matches.some(m => m.left === "Q10" && m.right === correctMap.Q10)) score++;
            return score;
        }

        // remove match by leftId
        function removeMatchByLeft(leftId) {
            matches = matches.filter(m => m.left !== leftId);
        }

        function setMatch(leftId, rightId) {
            removeMatchByLeft(leftId);
            matches.push({ left: leftId, right: rightId });
            redrawLines();
            // subtle hint if both are perfectly matched before final step
            if (computeCurrentScore() === 2 && currentStep < 2 && !confettiTriggeredForPerfect) {
                hintMsg.innerHTML = "🎯 Perfect answers so far! Complete the quiz to see your final score & celebration.";
                setTimeout(() => {
                    if (currentStep < 2 && hintMsg.innerHTML.includes("Perfect answers")) {
                        hintMsg.innerHTML = currentStep === 0 ? "💡 Tap 'Marketing research...' then Yes/No" : "💡 Tap Question 10, then choose the attribute";
                    }
                }, 2800);
            }
        }

        // redraw lines
        function redrawLines() {
            svg.innerHTML = "";
            if (!container) return;
            const containerRect = container.getBoundingClientRect();
            if (containerRect.width === 0) return;

            matches.forEach(match => {
                const leftElem = Array.from(leftCards).find(el => el.dataset.id === match.left);
                const rightElem = Array.from(rightCards).find(el => el.dataset.id === match.right);
                if (leftElem && rightElem && isVisible(leftElem) && isVisible(rightElem)) {
                    const leftRect = leftElem.getBoundingClientRect();
                    const rightRect = rightElem.getBoundingClientRect();
                    const contRect = container.getBoundingClientRect();
                    
                    const x1 = leftRect.right - contRect.left;
                    const y1 = leftRect.top + leftRect.height / 2 - contRect.top;
                    const x2 = rightRect.left - contRect.left;
                    const y2 = rightRect.top + rightRect.height / 2 - contRect.top;
                    
                    const line = document.createElementNS("http://www.w3.org/2000/svg", "line");
                    line.setAttribute("x1", x1);
                    line.setAttribute("y1", y1);
                    line.setAttribute("x2", x2);
                    line.setAttribute("y2", y2);
                    line.setAttribute("stroke", "#4499bb");
                    line.setAttribute("stroke-width", "3");
                    line.setAttribute("stroke-linecap", "round");
                    line.setAttribute("opacity", "0.85");
                    svg.appendChild(line);
                }
            });
        }

        function isVisible(el) {
            return el && !el.classList.contains("hidden");
        }

        // ---------- CONFETTI EFFECT (for perfect score) ----------
        const canvas = document.getElementById("confetti-canvas");
        let ctx = canvas.getContext("2d");
        let animationId = null;
        let particles = [];

        function resizeCanvas() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        }
        window.addEventListener("resize", () => {
            resizeCanvas();
        });

        class ConfettiParticle {
            constructor(x, y) {
                this.x = x || Math.random() * canvas.width;
                this.y = y || -10;
                this.size = Math.random() * 8 + 4;
                this.speedY = Math.random() * 5 + 3;
                this.speedX = (Math.random() - 0.5) * 4;
                this.color = `hsl(${Math.random() * 360}, 80%, 60%)`;
                this.rotation = Math.random() * 360;
                this.rotationSpeed = (Math.random() - 0.5) * 8;
                this.opacity = 1;
            }
            update() {
                this.x += this.speedX;
                this.y += this.speedY;
                this.rotation += this.rotationSpeed;
                if (this.y > canvas.height + 100 || this.x < -100 || this.x > canvas.width + 100) {
                    return false;
                }
                return true;
            }
            draw() {
                ctx.save();
                ctx.translate(this.x, this.y);
                ctx.rotate((this.rotation * Math.PI) / 180);
                ctx.fillStyle = this.color;
                ctx.fillRect(-this.size/2, -this.size/2, this.size, this.size);
                ctx.restore();
            }
        }

        function launchConfetti(duration = 2800) {
            if (animationId) {
                cancelAnimationFrame(animationId);
                particles = [];
            }
            for (let i = 0; i < 200; i++) {
                particles.push(new ConfettiParticle());
            }
            let startTime = performance.now();
            function animateConfetti(now) {
                if (!ctx) return;
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                let allDead = true;
                for (let i = 0; i < particles.length; i++) {
                    const alive = particles[i].update();
                    if (alive) allDead = false;
                    particles[i].draw();
                }
                if (allDead || (now - startTime > duration)) {
                    cancelAnimationFrame(animationId);
                    animationId = null;
                    ctx.clearRect(0, 0, canvas.width, canvas.height);
                    particles = [];
                    return;
                }
                animationId = requestAnimationFrame(animateConfetti);
            }
            animationId = requestAnimationFrame(animateConfetti);
            setTimeout(() => {
                if (animationId) {
                    cancelAnimationFrame(animationId);
                    animationId = null;
                    ctx.clearRect(0, 0, canvas.width, canvas.height);
                    particles = [];
                }
            }, duration + 200);
        }

        function burstCelebration() {
            launchConfetti(3200);
            setTimeout(() => {
                if (canvas) {
                    for(let i=0;i<50;i++) {
                        setTimeout(() => {
                            if(!animationId) launchConfetti(1500);
                        }, i*40);
                    }
                }
            }, 200);
        }
        
        // ----- Show final score at the top after completion (not live) -----
        function showFinalScoreInHeader() {
            const score = computeCurrentScore();
            const total = Object.keys(correctMap).length;
            finalScoreValueSpan.innerHTML = `${score} <span>/ ${total}</span>`;
            finalScoreBadge.style.display = "block";
            
            // add perfect styling if applicable
            if (score === total) {
                finalScoreBadge.classList.add("perfect-score-top");
                // Optionally add confetti if not triggered yet (triggered in final evaluation)
            } else {
                finalScoreBadge.classList.remove("perfect-score-top");
            }
        }

        // update UI based on step
        function updateUIByStep() {
            if (currentStep === 0) {
                q0Card.classList.remove("hidden");
                q0Card.classList.add("active");
                q1Card.classList.add("hidden");
                q1Card.classList.remove("active");
                q9Answers.forEach(ans => ans.classList.remove("hidden"));
                q10Answers.forEach(ans => ans.classList.add("hidden"));
                stepIndicator.innerText = "📘 Step 1 · Question 9";
                hintMsg.innerHTML = "💡 Tap 'Marketing research should be done by external researchers' then choose Yes or No";
            } 
            else if (currentStep === 1) {
                q0Card.classList.add("hidden");
                q0Card.classList.remove("active");
                q1Card.classList.remove("hidden");
                q1Card.classList.add("active");
                q9Answers.forEach(ans => ans.classList.add("hidden"));
                q10Answers.forEach(ans => ans.classList.remove("hidden"));
                stepIndicator.innerText = "📘 Step 2 · Question 10";
                hintMsg.innerHTML = "💡 Tap the second question, then select the attribute that is NOT required";
            } 
            else if (currentStep === 2) {
                stepIndicator.innerText = "✅ Assessment completed";
                hintMsg.innerHTML = "🎉 Great! Your final score is shown at the top.";
                nextButton.disabled = true;
                nextButton.style.opacity = "0.55";
                nextButton.style.cursor = "default";
                // show final score badge at top
                showFinalScoreInHeader();
                evaluateFinalScoreAndCelebrate();
                return;
            }
            if (selectedLeftCard) {
                selectedLeftCard.classList.remove("selected");
                selectedLeftCard = null;
            }
            redrawLines();
        }

        // final evaluation + confetti for perfect score (detailed message below)
        function evaluateFinalScoreAndCelebrate() {
            let score = 0;
            let feedbackQ9 = "", feedbackQ10 = "";
            
            const matchQ9 = matches.find(m => m.left === "Q9");
            const isQ9Correct = matchQ9 && matchQ9.right === correctMap.Q9;
            if (isQ9Correct) {
                score++;
                feedbackQ9 = "✓ <strong>Question 9</strong>: Correct — Marketing research can be internal OR external; there's no strict rule that only external researchers should do it.";
            } else {
                feedbackQ9 = "✗ <strong>Question 9</strong>: The correct answer is 'No'. Research can be done internally (by company teams) or externally based on needs.";
            }
            
            const matchQ10 = matches.find(m => m.left === "Q10");
            const isQ10Correct = matchQ10 && matchQ10.right === correctMap.Q10;
            if (isQ10Correct) {
                score++;
                feedbackQ10 = "✓ <strong>Question 10</strong>: Correct! Being a postgraduate & statistician is not an obligatory quality — ethics, experience, and professionalism matter more.";
            } else {
                feedbackQ10 = "✗ <strong>Question 10</strong>: The NOT required attribute is 'Postgraduate & statistician' (option B). A marketing researcher needs knowledge, ethics, energy & critical thinking, but not necessarily a postgraduate degree or statistician title.";
            }
            
            const total = Object.keys(correctMap).length;
            const percent = Math.round((score/total)*100);
            const isPerfect = (score === total);
            
            // CONFETTI for perfect 2/2
            if (isPerfect && !confettiTriggeredForPerfect) {
                confettiTriggeredForPerfect = true;
                burstCelebration();
            }
            
            resultArea.style.display = "block";
            resultArea.className = "result-panel";
            
            // Build the detailed result with the exact formatting requested: 
            // "🏅 Score: 2 / 2 · 100%  🌟 Congratulations! You nailed both questions! 🎊"
            let perfectMessage = "";
            if (isPerfect) {
                perfectMessage = `<div style="margin-top: 12px; background:#ffe5b4; padding:8px 16px; border-radius: 40px; display:inline-block; font-weight:600;">🌟 Congratulations! You nailed both questions! 🎊</div>`;
            }
            
            resultArea.innerHTML = `
                <div style="font-weight: 600; font-size:1rem; margin-bottom: 12px;">📊 Detailed Feedback</div>
                <div style="margin-bottom: 8px;">${feedbackQ9}</div>
                <div style="margin-bottom: 12px;">${feedbackQ10}</div>
                <div class="score-highlight" style="background: ${isPerfect ? '#ffe0a3' : '#e0f0f5'};">
                    🏅 Score: ${score} / ${total} · ${percent}%
                </div>
                ${perfectMessage}
            `;
            
            // Also update the top badge with the same score (already done in showFinalScoreInHeader)
            // but ensure perfect styling sync
            if (isPerfect) {
                finalScoreBadge.classList.add("perfect-score-top");
            } else {
                finalScoreBadge.classList.remove("perfect-score-top");
            }
        }
        
        // ---------- Event listeners ----------
        leftCards.forEach(card => {
            card.addEventListener("click", (e) => {
                e.stopPropagation();
                if (currentStep === 2) return;
                if (!card.classList.contains("active") || card.classList.contains("hidden")) return;
                
                if (selectedLeftCard) {
                    selectedLeftCard.classList.remove("selected");
                }
                selectedLeftCard = card;
                card.classList.add("selected");
                hintMsg.innerHTML = "✨ Now tap an answer on the right to connect.";
            });
        });
        
        rightCards.forEach(answer => {
            answer.addEventListener("click", (e) => {
                e.stopPropagation();
                if (currentStep === 2) return;
                if (!selectedLeftCard) {
                    hintMsg.innerHTML = "👈 First tap on a blue question card, then choose your answer.";
                    setTimeout(() => {
                        if (currentStep !== 2 && hintMsg.innerHTML.includes("First tap")) {
                            if(currentStep===0) hintMsg.innerHTML = "💡 Tap 'Marketing research should be done by external researchers' then choose Yes or No";
                            else if(currentStep===1) hintMsg.innerHTML = "💡 Tap the second question, then select the attribute that is NOT required";
                        }
                    }, 1800);
                    return;
                }
                
                const leftId = selectedLeftCard.dataset.id;
                if (!selectedLeftCard.classList.contains("active") || selectedLeftCard.classList.contains("hidden")) {
                    selectedLeftCard.classList.remove("selected");
                    selectedLeftCard = null;
                    hintMsg.innerHTML = "⚠️ Please select a visible question again.";
                    return;
                }
                
                const rightId = answer.dataset.id;
                if (currentStep === 0 && leftId === "Q9") {
                    if (answer.classList.contains("q9-group")) {
                        setMatch(leftId, rightId);
                        selectedLeftCard.classList.remove("selected");
                        selectedLeftCard = null;
                        hintMsg.innerHTML = "✓ Matched! Click 'Next step' to continue.";
                    } else {
                        hintMsg.innerHTML = "⛔ Please select an answer from the visible options (Yes/No).";
                        selectedLeftCard.classList.remove("selected");
                        selectedLeftCard = null;
                    }
                } 
                else if (currentStep === 1 && leftId === "Q10") {
                    if (answer.classList.contains("q10-group")) {
                        setMatch(leftId, rightId);
                        selectedLeftCard.classList.remove("selected");
                        selectedLeftCard = null;
                        hintMsg.innerHTML = "✓ Matched! Press 'Next step' to see your score.";
                    } else {
                        hintMsg.innerHTML = "⛔ Pick an answer from the four quality attributes.";
                        selectedLeftCard.classList.remove("selected");
                        selectedLeftCard = null;
                    }
                }
                else {
                    hintMsg.innerHTML = "🔄 Please match the visible question with its corresponding answer block.";
                    selectedLeftCard.classList.remove("selected");
                    selectedLeftCard = null;
                }
            });
        });
        
        function handleNext() {
            if (currentStep === 0) {
                const hasMatchQ9 = matches.some(m => m.left === "Q9");
                if (!hasMatchQ9) {
                    hintMsg.innerHTML = "⚠️ Please match Question 9 first (tap the question, then select Yes/No).";
                    return;
                }
                currentStep = 1;
                updateUIByStep();
                if (selectedLeftCard) {
                    selectedLeftCard.classList.remove("selected");
                    selectedLeftCard = null;
                }
                setTimeout(() => redrawLines(), 30);
            } 
            else if (currentStep === 1) {
                const hasMatchQ10 = matches.some(m => m.left === "Q10");
                if (!hasMatchQ10) {
                    hintMsg.innerHTML = "⚠️ Please match Question 10 before finishing.";
                    return;
                }
                currentStep = 2;
                updateUIByStep();  // this shows final score badge and detailed result
                redrawLines();
            }
        }
        
        // resize & observer
        let resizeTimer;
        window.addEventListener("resize", () => {
            if (resizeTimer) clearTimeout(resizeTimer);
            resizeTimer = setTimeout(() => {
                if (container) redrawLines();
                resizeCanvas();
            }, 100);
        });
        
        const resizeObserver = new ResizeObserver(() => {
            if (container && currentStep !== undefined) redrawLines();
        });
        resizeObserver.observe(container);
        leftCards.forEach(c => resizeObserver.observe(c));
        rightCards.forEach(c => resizeObserver.observe(c));
        
        function init() {
            currentStep = 0;
            matches = [];
            selectedLeftCard = null;
            confettiTriggeredForPerfect = false;
            q0Card.classList.remove("hidden");
            q0Card.classList.add("active");
            q1Card.classList.add("hidden");
            q1Card.classList.remove("active");
            q9Answers.forEach(a => a.classList.remove("hidden"));
            q10Answers.forEach(a => a.classList.add("hidden"));
            stepIndicator.innerText = "📘 Step 1 · Question 9";
            hintMsg.innerHTML = "✨ Click a blue question, then tap an answer";
            nextButton.disabled = false;
            nextButton.style.opacity = "1";
            nextButton.style.cursor = "pointer";
            resultArea.style.display = "none";
            resultArea.innerHTML = "";
            svg.innerHTML = "";
            leftCards.forEach(c => c.classList.remove("selected"));
            if (selectedLeftCard) selectedLeftCard.classList.remove("selected");
            selectedLeftCard = null;
            // hide final score badge until completion
            finalScoreBadge.style.display = "none";
            finalScoreBadge.classList.remove("perfect-score-top");
            redrawLines();
            if (animationId) {
                cancelAnimationFrame(animationId);
                animationId = null;
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                particles = [];
            }
            resizeCanvas();
        }
        
        nextButton.addEventListener("click", handleNext);
        document.addEventListener("click", function(e) {
            if (currentStep === 2) return;
            const isLeftCard = e.target.closest(".left .q-item");
            const isRightCard = e.target.closest(".right .ans-block");
            if (!isLeftCard && !isRightCard && selectedLeftCard) {
                selectedLeftCard.classList.remove("selected");
                selectedLeftCard = null;
                if (currentStep === 0) hintMsg.innerHTML = "💡 Tap a question first, then the answer.";
                else if (currentStep === 1) hintMsg.innerHTML = "💡 Tap Question 10, then choose the right attribute.";
            }
        });
        
        init();
        setTimeout(() => redrawLines(), 80);
    })();
</script>
</body>
</html>
